# URL del backend FastAPI (tu máquina local)
# En desarrollo:
NEXT_PUBLIC_API_URL=http://localhost:8000
# En producción (Vercel): cambia esto a tu IP pública o dominio
# NEXT_PUBLIC_API_URL=http://tu-ip-local:8000

# API Key para autenticarse con el backend (misma que en backend/.env)
NEXT_PUBLIC_API_KEY=tu-api-key-secreta-aqui